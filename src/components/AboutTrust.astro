---
import { Check, Users, Hammer, HandCoins, MessageCircle } from "lucide-astro";

const pillars = [
  {
    icon: Users,
    title: "Familienbetrieb seit 1960",
    text: "Drei Generationen Schreinerhandwerk in Duisburg-Neudorf – gewachsen, verlässlich, persönlich.",
  },
  {
    icon: Hammer,
    title: "Jahrelange Erfahrung",
    text: "Individueller Möbelbau, Kunststoff- und Holzfensterbau sowie alle Arbeiten im Innenausbau.",
  },
  {
    icon: MessageCircle,
    title: "Persönliche Beratung",
    text: "Wir stehen Ihnen gerne persönlich in unserer Werkstatt und telefonisch zur Verfügung.",
  },
  {
    icon: HandCoins,
    title: "Fair und direkt",
    text: "Ehrliche Einschätzung, klare Absprachen und sauber ausgeführte Arbeit – ohne Umwege.",
  },
];
---

<section id="ueber-uns" class="section bg-cream-50 border-y border-cream-200">
  <div class="container-page grid lg:grid-cols-12 gap-14 items-start">
    <div class="lg:col-span-5 lg:sticky lg:top-28">
      <div class="relative">
        <div
          class="aspect-[4/5] rounded-2xl overflow-hidden shadow-[var(--shadow-card)]"
          style="background: linear-gradient(180deg, #2d1f13 0%, #5a3a1e 60%, #8a5a2b 100%);"
          aria-hidden="true"
        >
          <div
            class="w-full h-full opacity-25 mix-blend-overlay"
            style="background-image: repeating-linear-gradient(80deg, rgba(255,255,255,0.06) 0 1px, transparent 1px 9px), repeating-linear-gradient(0deg, rgba(0,0,0,0.05) 0 1px, transparent 1px 18px);"
          >
          </div>
        </div>

        <div
          class="absolute -bottom-8 right-6 sm:-right-8 bg-cream rounded-xl p-6 shadow-[var(--shadow-card)] border border-cream-200 max-w-[280px]"
        >
          <p class="text-xs uppercase tracking-[0.16em] text-muted">Familienbetrieb</p>
          <p class="mt-1 font-serif text-4xl text-walnut">
            seit <span class="text-wood">1960</span>
          </p>
          <p class="mt-2 text-sm text-muted leading-relaxed">
            Ihre Schreinerei in Duisburg-Neudorf – über sechs Jahrzehnte
            Handwerk.
          </p>
        </div>
      </div>
    </div>

    <div class="lg:col-span-7">
      <span class="eyebrow">
        <span class="inline-block w-6 h-px bg-wood"></span>
        Über uns
      </span>
      <h2 class="mt-5 text-4xl sm:text-5xl">
        Ihr erfahrener Partner für<br />
        <span class="text-wood">Schreinerarbeiten</span>.
      </h2>

      <div class="mt-6 space-y-5 text-muted text-lg leading-relaxed">
        <p>
          Herzlich Willkommen auf der Website der Bau- und Möbelschreinerei
          Markus Rosch. Wir freuen uns, Sie bei uns begrüßen zu dürfen.
        </p>
        <p>
          Die Schreinerei M. Rosch ist Ihr erfahrener Partner für alle
          Schreinerarbeiten in Ihrem Haus oder Eigentum. Profitieren Sie von
          unserer jahrelangen Erfahrung im individuellen Möbelbau, Kunststoff-
          und Holzfensterbau und allen Arbeiten im Innenausbau.
        </p>
        <p>
          Für Ihre Fragen stehen wir Ihnen gerne persönlich in unserer Werkstatt
          und telefonisch zur Verfügung. Vereinbaren Sie telefonisch einen
          Besichtigungstermin für eine Beratung.
        </p>
      </div>

      <ul class="mt-12 grid sm:grid-cols-2 gap-6">
        {
          pillars.map(({ icon: Icon, title, text }) => (
            <li class="flex gap-4">
              <span class="grid place-items-center w-10 h-10 rounded-full bg-cream-100 text-wood shrink-0">
                <Icon class="w-5 h-5" />
              </span>
              <div>
                <p class="font-serif text-lg text-walnut">{title}</p>
                <p class="mt-1 text-sm text-muted leading-relaxed">{text}</p>
              </div>
            </li>
          ))
        }
      </ul>

      <p class="mt-10 font-serif text-xl text-walnut">
        Ihre Schreinerei Markus Rosch.
      </p>
    </div>
  </div>
</section>
