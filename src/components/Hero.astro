---
import { Phone, ArrowRight, MapPin, Hammer, Users } from "lucide-astro";
---

<section
  class="relative overflow-hidden border-b border-cream-200"
  style="background: radial-gradient(1200px 600px at 85% -10%, rgba(201,167,122,0.28), transparent 60%), linear-gradient(180deg, var(--color-cream-50), var(--color-cream));"
>
  <div
    class="container-page pt-20 pb-24 sm:pt-28 sm:pb-32 grid lg:grid-cols-12 gap-12 items-center"
  >
    <div class="lg:col-span-7">
      <span class="eyebrow">
        <span class="inline-block w-6 h-px bg-wood"></span>
        Familienbetrieb seit 1960
      </span>

      <h1 class="mt-6 text-4xl sm:text-5xl lg:text-6xl leading-[1.1] tracking-tight">
        Ihre Bau- und Möbelschreinerei<br />
        in <span class="text-wood">Duisburg-Neudorf</span>.
      </h1>

      <p class="mt-7 max-w-xl text-lg text-muted leading-relaxed">
        Herzlich Willkommen bei der Schreinerei Markus Rosch. Seit über 60&nbsp;Jahren
        Ihr erfahrener Partner für individuellen Möbelbau, Kunststoff- und
        Holzfensterbau sowie alle Arbeiten im Innenausbau.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a href="tel:+4920337118" class="btn btn-primary">
          <Phone class="w-4 h-4" />
          0203 37 01 18
        </a>
        <a href="#kontakt" class="btn btn-secondary">
          Termin vereinbaren
          <ArrowRight class="w-4 h-4" />
        </a>
      </div>

      <p class="mt-5 text-sm text-muted">
        Vereinbaren Sie gerne telefonisch einen Besichtigungstermin für eine
        persönliche Beratung in unserer Werkstatt.
      </p>

      <dl class="mt-12 grid grid-cols-3 gap-6 max-w-lg border-t border-cream-200 pt-8">
        <div>
          <dt class="flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-muted">
            <Users class="w-3.5 h-3.5" /> Seit
          </dt>
          <dd class="mt-2 font-serif text-3xl text-walnut">1960</dd>
        </div>
        <div>
          <dt class="flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-muted">
            <MapPin class="w-3.5 h-3.5" /> Standort
          </dt>
          <dd class="mt-2 font-serif text-lg text-walnut leading-tight">
            Duisburg-<br />Neudorf
          </dd>
        </div>
        <div>
          <dt class="flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-muted">
            <Hammer class="w-3.5 h-3.5" /> Betrieb
          </dt>
          <dd class="mt-2 font-serif text-lg text-walnut leading-tight">
            Meister-<br />werkstatt
          </dd>
        </div>
      </dl>
    </div>

    <div class="lg:col-span-5">
      <div class="relative">
        <div
          class="aspect-[4/5] rounded-2xl overflow-hidden shadow-[var(--shadow-card)]"
          style="background: linear-gradient(160deg, #c9a77a 0%, #8a5a2b 55%, #5a3a1e 100%);"
          aria-hidden="true"
        >
          <div
            class="w-full h-full opacity-30 mix-blend-overlay"
            style="background-image: repeating-linear-gradient(90deg, rgba(255,255,255,0.05) 0 2px, transparent 2px 14px), repeating-linear-gradient(0deg, rgba(0,0,0,0.06) 0 1px, transparent 1px 8px);"
          >
          </div>
        </div>

        <div
          class="absolute -bottom-6 -left-6 bg-cream rounded-xl p-5 shadow-[var(--shadow-card)] border border-cream-200 max-w-[260px]"
        >
          <p class="text-xs uppercase tracking-[0.16em] text-muted">Familienbetrieb</p>
          <p class="mt-1 font-serif text-2xl text-walnut">seit 1960</p>
          <p class="mt-1 text-xs text-muted">Drei Generationen Schreinerhandwerk.</p>
        </div>

        <div
          class="absolute -top-6 -right-6 bg-cream rounded-xl p-5 shadow-[var(--shadow-card)] border border-cream-200 max-w-[260px] hidden sm:block"
        >
          <div class="flex items-center gap-3">
            <span class="grid place-items-center w-10 h-10 rounded-full bg-cream-100 text-wood">
              <MapPin class="w-5 h-5" />
            </span>
            <div>
              <p class="text-xs uppercase tracking-[0.16em] text-muted">Werkstatt</p>
              <p class="text-sm text-walnut font-medium">Blumenstr. 73, Duisburg</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
