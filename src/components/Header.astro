---
import { Phone, Menu, X } from "lucide-astro";

const nav = [
  { label: "Leistungen", href: "#leistungen" },
  { label: "Über uns", href: "#ueber-uns" },
  { label: "Kontakt", href: "#kontakt" },
];
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-cream/85 border-b border-cream-200">
  <div class="container-page flex h-20 items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <span
        class="grid place-items-center w-10 h-10 rounded-full bg-walnut text-cream font-serif text-lg"
        >R</span
      >
      <span class="leading-tight">
        <span class="block font-serif text-lg text-walnut">Schreinerei Rosch</span>
        <span class="block text-[10px] sm:text-xs tracking-[0.18em] uppercase text-muted"
          >Duisburg-Neudorf · seit 1960</span
        >
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-sm text-walnut/80 hover:text-walnut transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:flex items-center gap-3">
      <a href="tel:+4920337118" class="btn btn-ghost text-sm">
        <Phone class="w-4 h-4" />
        0203 37 01 18
      </a>
      <a href="#kontakt" class="btn btn-primary">Termin vereinbaren</a>
    </div>

    <button
      type="button"
      class="md:hidden grid place-items-center w-10 h-10 rounded-full text-walnut hover:bg-cream-100"
      data-menu-toggle
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <Menu class="w-5 h-5" data-menu-icon="open" />
      <X class="w-5 h-5 hidden" data-menu-icon="close" />
    </button>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-cream-200 bg-cream"
    data-menu-panel
  >
    <nav class="container-page py-6 flex flex-col gap-4">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="py-2 text-base text-walnut hover:text-wood"
            data-menu-link
          >
            {item.label}
          </a>
        ))
      }
      <a href="tel:+4920337118" class="btn btn-secondary mt-2 w-full" data-menu-link>
        <Phone class="w-4 h-4" />
        0203 37 01 18
      </a>
      <a href="#kontakt" class="btn btn-primary w-full" data-menu-link>
        Termin vereinbaren
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const panel = document.querySelector<HTMLElement>("[data-menu-panel]");
  const iconOpen = document.querySelector<HTMLElement>("[data-menu-icon='open']");
  const iconClose = document.querySelector<HTMLElement>("[data-menu-icon='close']");
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-menu-link]");

  const setOpen = (open: boolean) => {
    if (!panel || !toggle) return;
    panel.classList.toggle("hidden", !open);
    iconOpen?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Menü schließen" : "Menü öffnen");
  };

  toggle?.addEventListener("click", () => {
    const isOpen = panel?.classList.contains("hidden");
    setOpen(!!isOpen);
  });

  links.forEach((link) => link.addEventListener("click", () => setOpen(false)));
</script>
